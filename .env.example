# ─── PostgreSQL (required) ───────────────────────────────────────────
# Local Docker: docker compose up -d
DATABASE_URL="postgresql://sentinel:sentinel_dev@localhost:5432/sentinelai?schema=public"

# ─── Firebase Client (browser — from Firebase Console → Project settings) ─
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server — service account JSON as single line or file path) ─
# Option A: path to downloaded service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Option B: entire JSON string (useful for deployment)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── FastAPI backend ─────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8000

# YOLO detection on phone camera frames (optional)
YOLO_ENABLED=true
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4
YOLO_INTERVAL_MS=1000

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_EVENT_SLUG=summit-2026
# ngrok HTTPS URL for phone camera broadcast links (optional)
# NEXT_PUBLIC_APP_URL=https://your-subdomain.ngrok-free.app
