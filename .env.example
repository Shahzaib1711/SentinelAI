# ─── Neon PostgreSQL (recommended) ───────────────────────────────────
# From https://console.neon.tech → your project → Connect
# Use the *pooled* string for DATABASE_URL and the *direct* string for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Local PostgreSQL (optional — Docker: npm run db:up) ─────────────
# Comment out DATABASE_URL/DIRECT_URL above and use these instead.
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_NAME=sentinelai
# DB_SCHEMA=public
# DB_SSLMODE=disable

# ─── Firebase Client (browser — from Firebase Console → Project settings) ─
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server — service account JSON as single line or file path) ─
# Option A: path to downloaded service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Option B: entire JSON string (useful for deployment)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ─── FastAPI backend ─────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8000

# YOLO detection on phone camera frames (optional)
YOLO_ENABLED=true
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4
YOLO_INTERVAL_MS=1000

# Face recognition match threshold (0.0–1.0, higher = stricter)
FACE_MATCH_THRESHOLD=0.45

# Blueprint marker detection — custom YOLO (falls back to OpenCV if model missing)
BLUEPRINT_ML_ENABLED=true
BLUEPRINT_ML_MODEL=backend/app/models/sentinel_blueprint.pt
BLUEPRINT_ML_CONFIDENCE=0.35

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_EVENT_SLUG=summit-2026
# ngrok HTTPS URL for phone camera broadcast links (optional)
# NEXT_PUBLIC_APP_URL=https://your-subdomain.ngrok-free.app
