{
  "name": "sentinel-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/with-database-url.mjs npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "node scripts/with-database-url.mjs npx prisma generate",
    "db:migrate": "node scripts/with-database-url.mjs npx prisma migrate dev",
    "db:push": "node scripts/with-database-url.mjs npx prisma db push --skip-generate",
    "db:seed": "node scripts/with-database-url.mjs npx prisma db seed",
    "db:studio": "node scripts/with-database-url.mjs npx prisma studio",
    "db:up": "docker compose up -d",
    "api:install": "cd backend && python -m pip install -r requirements.txt",
    "api:dev": "cd backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^12.7.0",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "peerjs": "^1.5.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
